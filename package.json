{
  "name": "nest-scaffold",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:swc": "nest build --builder swc --type-check",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=\"development\" nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:dist": "node dist/src/main",
    "start:swc": "nest start --builder swc --type-check",
    "start:swc:dev": "cross-env NODE_ENV=\"development\" nest start --builder swc --type-check --watch",
    "start:swc:debug": "nest start --builder swc --type-check --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./jest-e2e.config.ts",
    "vitest": "vitest run",
    "vitest:watch": "vitest",
    "vitest:cov": "vitest run --coverage",
    "vitest:debug": "vitest run --inspect-brk --no-file-parallelism --test-timeout=0",
    "vitest:e2e": "vitest run --config ./vitest-e2e.config.ts",
    "db:init:dev": "cross-env NODE_ENV=\"development\" nest start --entryFile ./src/common/modules/database/tools/init.main",
    "db:seed:dev": "cross-env NODE_ENV=\"development\" nest start --entryFile ./src/common/modules/database/tools/seed.main",
    "db:init:prod": "cross-env NODE_ENV=\"production\" node dist/src/common/modules/database/tools/init.main",
    "db:seed:prod": "cross-env NODE_ENV=\"production\" node dist/src/common/modules/database/tools/seed.main",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.70.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dayjs": "^1.11.19",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "inquirer": "^13.3.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.18.2",
    "nestjs-i18n": "^10.6.0",
    "nestjs-pino": "^4.6.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "redlock": "5.0.0-beta.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@bull-board/nestjs": "^6.20.3",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "commitizen": "^4.3.1",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
